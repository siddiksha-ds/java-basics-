import java.util.Scanner;
class Main{
    public static void main(String args[]){
    Scanner sc=new Scanner(System.in);
    int Count=0;
    System.out.println("enter the number");
    int n=sc.nextInt();
    for(int i=2;i<n;i++){
        if(n%i==0){
            Count++;
        }
    }
    if(Count==0&&n>1){
        System.out.println("number is prime");
    }
    else{
        System.out.println("number is not prime");
    }
    }
}
